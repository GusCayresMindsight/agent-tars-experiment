# Copy this file to .env and fill in at least one key before running make run-*.
# The .env file is gitignored — never commit real credentials.

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Volcengine (Doubao / Seed-VL) API key — get one at https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
VOLC_API_KEY=...
